{
  "appId": "com.naveenneog.bharatiyaitihasa",
  "appName": "Bharatiya Itihasa",
  "webDir": "www",
  "server": {
    "url": "https://indian-history.web.app",
    "cleartext": false
  },
  "android": {
    "backgroundColor": "#0d0b09"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1800,
      "launchAutoHide": true,
      "backgroundColor": "#0d0b09",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0d0b09",
      "overlaysWebView": true
    }
  }
}
